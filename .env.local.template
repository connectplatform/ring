# ============================================================================
# LOCALES (Ring Platform — lib/locale-config.ts)
# ============================================================================
# Comma-separated BCP 47 short codes; must match folders under locales/
NEXT_PUBLIC_SUPPORTED_LOCALES=en,uk,ru
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Optional: legacy browser gate site name (default: Ring Platform)
# NEXT_PUBLIC_LEGACY_BROWSER_SITE_NAME=Ring Platform

# ============================================================================
# RING MCP SERVICE GATEWAY (/api/mcp/v1/*)
# ============================================================================
# Comma-separated bearer tokens for ring-mcp (AI-RING/ring-mcp). Never commit real values.
# RING_MCP_SERVICE_TOKENS=dev-only-change-me
# Optional synthetic service user identity (defaults shown)
# RING_MCP_SERVICE_USER_ID=ring-mcp-service
# RING_MCP_SERVICE_USER_EMAIL=ring-mcp@system.local
# RING_MCP_SERVICE_USER_NAME=Ring MCP Service
