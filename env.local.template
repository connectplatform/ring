# ============================================================================
# REFERRAL CODES MODULE (refcodes — server-side gasless minter)
# ============================================================================
# Required for on-chain mint after WayForPay approval or credit checkout.
# Exclude all REFERRAL_* keys from Reggie propagate (.reggie-propagate-exclude.json).
#
# Deploy contract (from ring-platform.org/contracts/):
#   REFERRAL_REWARD_TOKEN_ADDRESS=0x... REFERRAL_MINTER_ADDRESS=0x... REFERRAL_REWARD_MODE=0 \
#   DEPLOYER_PRIVATE_KEY=0x... npx hardhat run scripts/deploy-referral-rewards.js --network polygon
#
# MINT mode (REFERRAL_REWARD_MODE=0): grant token minter to ReferralRewards proxy:
#   Ownable token → token.transferOwnership(REFERRAL_REWARDS_ADDRESS)
#   AccessControl → token.grantRole(MINTER_ROLE, REFERRAL_REWARDS_ADDRESS)

# Server operator wallet — must hold OPERATOR_ROLE on ReferralRewards (never client-side)
# REFERRAL_MINTER_PRIVATE_KEY=

# Optional: operator address fallback for contracts/scripts/deploy-referral-rewards.js
# REFERRAL_MINTER_ADDRESS=0x0000000000000000000000000000000000000000

# UUPS proxy from deploy-referral-rewards.js output
# REFERRAL_REWARDS_ADDRESS=

# Mintable ERC20 on target chain (per-clone reward token)
# REFERRAL_REWARD_TOKEN_ADDRESS=

# Reward sizing (defaults shown)
# Precedence: product.referralCommission → merchant commissionStructure →
# DEFAULT_COMMISSION_STRUCTURE.referralCommission (constants/store.ts) → REFERRAL_REWARD_PERCENT
REFERRAL_REWARD_PERCENT=5
REFERRAL_COMMISSION_MAX_PERCENT=50
REFERRAL_CHAIN_ID=137
REFERRAL_UAH_PER_USD=40

# 0 = MINT (IMintableERC20.mint), 1 = TRANSFER (treasury must fund contract)
REFERRAL_REWARD_MODE=0

# DEPLOYER_PRIVATE_KEY=  
# Hardhat deploy only — not used at Next.js runtime

# Cron auth for /api/cron/refcodes-mint (fail-closed: route returns 401 until set)
# CRON_SECRET=

# ============================================================================
