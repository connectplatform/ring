# Ring Platform Environment Configuration
# Copy to .env.local and fill in values. Never commit .env.local.

# ============================================================================
# PLATFORM CONFIGURATION
# ============================================================================

NEXT_PUBLIC_BASE_URL=https://ring-platform.org
NODE_ENV=development
DEBUG_MODE=false

# ============================================================================
# LOCALES (lib/locale-config.ts)
# ============================================================================
# Comma-separated BCP 47 short codes; must match folders under locales/
NEXT_PUBLIC_SUPPORTED_LOCALES=en,uk,ru
NEXT_PUBLIC_DEFAULT_LOCALE=en

# Optional: legacy browser gate site name (default: Ring Platform)
# NEXT_PUBLIC_LEGACY_BROWSER_SITE_NAME=Ring Platform

# =============================================================================
# 🗄️ DATABASE BACKEND CONFIGURATION
# =============================================================================
# Ring Platform supports three sophisticated backend deployment modes:
#
# 1. k8s-postgres-fcm (RECOMMENDED FOR PRODUCTION & LOCAL DEV)
#    - PostgreSQL on Kubernetes for all database operations
#    - Firebase for FCM push notifications only
#    - Apple Push Notification Service for iOS
#    - Best performance and cost-efficiency for self-hosted deployments
#    - USE THIS FOR LOCAL DEVELOPMENT with local PostgreSQL
#
# 2. firebase-full (RAPID DEVELOPMENT / VERCEL EDGE)
#    - Firebase Firestore for all database operations
#    - Firebase for FCM push notifications
#    - Fastest setup for prototyping and Vercel Edge deployments
#    - Pay-per-use pricing model
#
# 3. supabase-fcm (CLOUD POSTGRESQL)
#    - Supabase PostgreSQL for database operations
#    - Firebase for FCM push notifications only
#    - Apple Push Notification Service for iOS
#    - Best for cloud-hosted PostgreSQL without Kubernetes

# CRITICAL: This variable is REQUIRED — the platform will not start without it
# For local development with PostgreSQL, use: k8s-postgres-fcm
DB_BACKEND_MODE=k8s-postgres-fcm

# PostgreSQL Configuration (required for k8s-postgres-fcm and supabase-fcm modes)
# Canonical local dev: container ring-postgres-dev (postgres:16-alpine), volume ringdom_postgres_data, port 5432.
# Alternative single URL (optional): DATABASE_URL=postgresql://ring_user:ring_password_2024@localhost:5432/ring_platform
# ring-postgres-dev: match POSTGRES_USER / POSTGRES_PASSWORD from docker-compose.dev.yml.
# POSTGRES_DB on the server (ring_file_registry) is for AI-RINGDOM/ring-file-registry only — do not set DB_NAME to that for this app.
# Local dev DB name: ring_platform (created by infrastructure/postgres/init/00-create-ring-platform-db.sh). Production: ring_platform.
DB_HOST=localhost  # Use 'postgres.ring-platform-org.svc.cluster.local' for K8s
DB_PORT=5432
DB_NAME=ring_platform
DB_USER=ring_user
DB_PASSWORD=ring_password_2024
DB_POOL_SIZE=20
DB_TIMEOUT=30000
DB_RETRIES=3
DB_SSL=false  # Set to 'true' for production and Supabase

# PostGIS Extension (optional — reverse propagated from ring-pet-friend)
# Enable for: Store delivery radius, entity locations, event venues, real estate
# PostGIS extensions are added to schema.sql automatically if enabled
DB_ENABLE_POSTGIS=false

# Supabase Configuration (only for supabase-fcm mode)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

